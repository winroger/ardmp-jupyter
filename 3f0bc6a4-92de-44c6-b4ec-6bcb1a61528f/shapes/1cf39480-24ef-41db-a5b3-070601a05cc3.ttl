@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .

aps:1cf39480-24ef-41db-a5b3-070601a05cc3
  dcterms:created "2026-05-07"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit geolocation node shape extended with GeoNames identifier and place label."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit geolocation node shape"@en ;
  a sh:NodeShape ;
  rdfs:label "Location"@en ;
  owl:imports aps:beeb6ea5-92df-417a-8447-9a4b0b187ed7 ;
  sh:closed false ;
  sh:node aps:beeb6ea5-92df-417a-8447-9a4b0b187ed7 ;
  sh:property [
    sh:order 3 ;
    sh:name "GeoNames URI" ;
    sh:description "GeoNames IRI of the place, e.g. https://www.geonames.org/1234567."@en ;
    sh:path dcterms:identifier ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
    sh:pattern "^https?://www\\.geonames\\.org/[0-9]+(/.*)?$" ;
  ], [
    sh:order 4 ;
    sh:name "GeoNames ID" ;
    sh:description "GeoNames numeric identifier as literal text, e.g. 1234567."@en ;
    sh:path aps:geonamesId ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:pattern "^[0-9]+$" ;
  ], [
    sh:order 5 ;
    sh:name "Place label" ;
    sh:description "Human-readable label of the place."@en ;
    sh:path rdfs:label ;
    sh:nodeKind sh:Literal ;
    sh:maxCount 1 ;
  ] ;
  sh:targetClass dcterms:Location .