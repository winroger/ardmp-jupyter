@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .

aps:6c98fa13-18d1-4b67-8cab-bd74df4e6fa9
  dcterms:created "2026-05-06"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit role node shape requiring a role IRI and human-readable label."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit role"@en ;
  a sh:NodeShape ;
  rdfs:label "Role"@en ;
  sh:closed false ;
  sh:nodeKind sh:IRI ;
  sh:class prov:Role ;
  sh:property [
    sh:order 1 ;
    sh:name "Label" ;
    sh:description "Label for the role."@en ;
    sh:path rdfs:label ;
    sh:datatype rdf:langString ;
    sh:minCount 1 ;
  ], [
    sh:order 2 ;
    sh:name "sameAs" ;
    sh:description "Exact or close match with external identifier for the role."@en ;
    sh:path owl:sameAs ;
    sh:nodeKind sh:IRI ;
  ] ;
  sh:targetClass prov:Role .