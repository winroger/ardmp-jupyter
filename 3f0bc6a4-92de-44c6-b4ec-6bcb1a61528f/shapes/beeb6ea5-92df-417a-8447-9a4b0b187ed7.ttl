<https://w3id.org/nfdi4ing/profiles/beeb6ea5-92df-417a-8447-9a4b0b187ed7> <http://purl.org/dc/terms/created> "2024-07-30"^^xsd:date;
                                                                          <http://purl.org/dc/terms/creator> "Stephan Tittel";
                                                                          <http://purl.org/dc/terms/description> "RO-kit Geolokation"@de,
                                                                                                                 "RO-kit geolocation"@en;
                                                                          <http://purl.org/dc/terms/license> <http://spdx.org/licenses/CC0-1.0>;
                                                                          <http://purl.org/dc/terms/title> "RO-kit Geolokation"@de,
                                                                                                           "RO-kit geolocation"@en;
                                                                          a <http://www.w3.org/ns/shacl#NodeShape>;
                                                                          rdfs:label "Location";
                                                                          <http://www.w3.org/ns/shacl#closed> false;
                                                                          <http://www.w3.org/ns/shacl#property> [<http://www.w3.org/ns/shacl#name> "Coordinates" ; 
                                                                                                                 <http://www.w3.org/ns/shacl#datatype> <http://www.opengis.net/ont/geosparql#wktLiteral> ; 
                                                                                                                 <http://www.w3.org/ns/shacl#maxCount> 1  ; 
                                                                                                                 <http://www.w3.org/ns/shacl#path> <http://www.opengis.net/ont/geosparql#asWKT> ; 
                                                                                                                 <http://www.w3.org/ns/shacl#order> 1  ; 
                                                                                                                 <http://www.w3.org/ns/shacl#pattern> "^POINT\\([+\\-]?(?:[0-9]*[.])?[0-9]+ [+\\-]?(?:[0-9]*[.])?[0-9]+\\)$|^POLYGON\\(\\((?:[+\\-]?(?:[0-9]*[.])?[0-9]+[ ,]?){3,}\\)\\)$" ; 
                                                                                                                 <http://www.w3.org/ns/shacl#minCount> 1  ; 
                                                                                                                 <http://www.w3.org/ns/shacl#description> "Format WKT, e.g. POINT(8.65 49.87)"],
                                                                                                                [<http://www.w3.org/ns/shacl#description> "Description of the location" ; 
                                                                                                                 <http://www.w3.org/ns/shacl#maxCount> 1  ; 
                                                                                                                 <http://www.w3.org/ns/shacl#path> <http://purl.org/dc/terms/description> ; 
                                                                                                                 <http://www.w3.org/ns/shacl#name> "Description" ; 
                                                                                                                 <http://www.w3.org/ns/shacl#order> 2 ];
                                                                          <http://www.w3.org/ns/shacl#targetClass> <http://purl.org/dc/terms/Location>.
