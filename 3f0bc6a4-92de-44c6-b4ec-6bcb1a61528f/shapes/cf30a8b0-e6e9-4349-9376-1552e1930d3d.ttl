@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .

aps:cf30a8b0-e6e9-4349-9376-1552e1930d3d
  dcterms:created "2026-04-17"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit node shape linked resource metadata."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit resource node shape"@en ;
  a sh:NodeShape ;
  rdfs:label "Linked Resource"@en ;
  sh:closed false ;
  sh:property [
    sh:order 1 ;
    sh:name "Name" ;
    sh:description "Name of the resource."@en ;
    sh:path schema:name ;
    sh:nodeKind sh:Literal ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:order 2 ;
    sh:name "URL" ;
    sh:description "URL of description resource."@en ;
    sh:path schema:url ;
    sh:datatype xsd:anyURI ;
    sh:maxCount 1 ;
  ], [
    sh:order 3 ;
    sh:name "Date visited" ;
    sh:description "Timestamp of when the resource was visited."@en ;
    sh:path schema:dateModified ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
  ] ;
  sh:targetClass rdfs:Resource .
