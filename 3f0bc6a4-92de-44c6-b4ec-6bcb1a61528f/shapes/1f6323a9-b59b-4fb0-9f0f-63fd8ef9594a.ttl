@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dnb: <https://d-nb.info/standards/elementset/dnb#> .
@prefix gndo: <https://d-nb.info/standards/elementset/gnd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix powder: <http://www.w3.org/2007/05/powder-s#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .



aps:1f6323a9-b59b-4fb0-9f0f-63fd8ef9594a
  dcterms:created "2026-04-17"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit buildings or memorial, abridged from EntityFacts for places."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit building"@en ;
  a sh:NodeShape ;
  rdfs:label "Building"@en ;
  owl:imports aps:1cf39480-24ef-41db-a5b3-070601a05cc3,
    aps:cf30a8b0-e6e9-4349-9376-1552e1930d3d,
    aps:e65fc010-5fe6-4d74-9333-8601c31dde5d;
    #<https://d-nb.info/standards/elementset/gnd> ;
  sh:closed false ;
  sh:property [
    sh:order 1 ;
    sh:name "Preferred name" ;
    sh:description "Preferred GND name for the building."@en ;
    sh:path gndo:preferredName ;
    sh:nodeKind sh:Literal ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:order 2 ;
    sh:name "Variant name" ;
    sh:description "Variant GND name for the building."@en ;
    sh:path gndo:variantName ;
    sh:nodeKind sh:Literal ;
  ], [
    sh:order 3 ;
    sh:name "Identifier" ;
    sh:description "Identifier of the building."@en ;
    sh:path gndo:gndIdentifier ;
    sh:datatype xsd:string ;
    sh:or (
      [
        rdfs:label "GND identifier" ;
        sh:description "GND identifier, e.g. 123456789-X."@en ;
        sh:pattern "^[1-9][0-9]{0,8}-[0-9X]$" ;
      ]
      [
        rdfs:label "Other" ;
        sh:description "Any other identifier in IRI or string form."@en ;
      ]
    ) ;
    sh:maxCount 1 ;
  ], [
    sh:order 4 ;
    sh:name "Stakeholder" ;
    sh:description "Stakeholder involved in the building project with the role of architect, engineer, or manufacturer."@en ;
    sh:path prov:qualifiedAttribution ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node aps:e65fc010-5fe6-4d74-9333-8601c31dde5d ;
  #], [
    #sh:order 5 ;
    #sh:name "Associated country" ;
    #sh:description "Geographic area code or country reference associated with the building."@en ;
    #sh:path gndo:geographicAreaCode ;
    #sh:nodeKind sh:IRI ;
    #sh:class skos:Concept ; #sh:class <https://d-nb.info/standards/vocab/gnd/geographic-area-code#GeographicAreaCodeValue> ;
    #owl:imports <https://raw.githubusercontent.com/winroger/gnd-country-codes/main/list.ttl> ;
  ], [
    sh:order 6 ;
    sh:name "Date of production" ;
    sh:description "Date of construction as a single year or a normalized year range."@en ;
    sh:path gndo:dateOfProduction ;
    sh:maxCount 1 ;
    sh:or (
      [
        sh:datatype xsd:gYear ;
        rdfs:label "Single year" ;
        sh:description "A single year in the format YYYY, e.g. 1927."@en ;
      ]
      [
        sh:datatype xsd:string ;
        rdfs:label "Year range" ;
        sh:description "A range of years in the format YYYY-YYYY, e.g. 1927-1930."@en ;
        sh:pattern "^[0-9]{4}[-–][0-9]{4}$" ;
      ]
    ) ;
  ], [
    sh:order 7 ;
    sh:name "Associated city" ;
    sh:description "Associated city from geonames, e.g. <https://www.geonames.org/1234567>."@en ;
    sh:path gndo:associatedPlace ;
    sh:nodeKind sh:IRI ;
    sh:pattern "^https?://www\\.geonames\\.org/[0-9]+(/.*)?$" ;
    #sh:class skos:Concept ;
    #owl:imports <https://raw.githubusercontent.com/winroger/geonames-cities-5000/refs/heads/main/cities5000-full.ttl> ;
  ], [
    sh:order 9 ;
    sh:name "Description" ;
    sh:description "Free-text description of the building."@en ;
    sh:path gndo:biographicalOrHistoricalInformation ;
    sh:nodeKind sh:Literal ;
    sh:maxCount 1 ;
  ], [
    sh:order 12 ;
    sh:name "Location" ;
    sh:description "Preferred structured geolocation for the building."@en ;
    sh:path dcterms:spatial ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node aps:1cf39480-24ef-41db-a5b3-070601a05cc3 ;
    sh:class dcterms:Location ;
    sh:maxCount 1 ;
  ], [
    sh:order 13 ;
    sh:name "Linked resource" ;
    sh:description "Linked resource, e.g. a file, URL, or other external resource."@en ;
    sh:path powder:describedby ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node aps:cf30a8b0-e6e9-4349-9376-1552e1930d3d ;
  ] ;
  sh:targetClass gndo:BuildingOrMemorial .
